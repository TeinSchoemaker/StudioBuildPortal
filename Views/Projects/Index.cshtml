@model List<StudioBuildPortal.Models.ProjectEntry>

<h1 class="mb-4">Studio Build Portal</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Add Project</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Branch</th>
            <th>Jenkins Job</th>
            <th>Status</th>
            <th>Build #</th>
            <th>Last Updated</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Name</td>
                <td>@project.Branch</td>
                <td>@project.JenkinsJobName</td>
                <td>@project.LastBuildStatus</td>
                <td>@project.LastBuildNumber</td>
                <td>@project.LastBuildTimeUtc</td>
                <td>
                    <form asp-action="TriggerBuild" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@project.Id" />
                        <button class="btn btn-sm btn-success" type="submit">Run Build</button>
                    </form>

                    <form asp-action="RefreshStatus" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@project.Id" />
                        <button class="btn btn-sm btn-secondary" type="submit">Refresh</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>