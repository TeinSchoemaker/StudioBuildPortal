@model StudioBuildPortal.Models.ProjectEntry

<h1>Add Project</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RepoUrl" class="form-label"></label>
        <input asp-for="RepoUrl" class="form-control" />
        <span asp-validation-for="RepoUrl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="JenkinsJobName" class="form-label"></label>
        <input asp-for="JenkinsJobName" class="form-control" />
        <span asp-validation-for="JenkinsJobName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Branch" class="form-label"></label>
        <input asp-for="Branch" class="form-control" />
        <span asp-validation-for="Branch" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>